<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="?android:colorBackground">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Logo -->
        <ImageView
            android:id="@+id/ivLogo"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="4dp"
            android:adjustViewBounds="true"
            android:scaleType="fitCenter"
            android:src="@drawable/petbionic_logo"
            android:contentDescription="@string/app_name" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/subtitle_monitor"
            android:textSize="12sp"
            android:textColor="?android:textColorSecondary"
            android:layout_gravity="center"
            android:layout_marginBottom="20dp"/>

        <!-- ── Device Status Card ─────────────────────────────────── -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardBackgroundColor="?attr/colorSurface"
            app:cardCornerRadius="16dp"
            app:cardElevation="2dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/device_status_label"
                    android:textSize="11sp"
                    android:textAllCaps="true"
                    android:letterSpacing="0.08"
                    android:textColor="?attr/colorOnSurface"
                    android:alpha="0.55"
                    android:layout_marginBottom="12dp"/>

                <!-- Connection dot + status text -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="16dp">

                    <View
                        android:id="@+id/viewConnectionDot"
                        android:layout_width="10dp"
                        android:layout_height="10dp"
                        android:layout_marginEnd="10dp"
                        android:background="@drawable/circle_indicator"/>

                    <TextView
                        android:id="@+id/tvStatus"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/status_disconnected"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:textColor="?attr/colorOnSurface"/>
                </LinearLayout>

                <!-- Sensor chips -->
                <com.google.android.material.chip.ChipGroup
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:singleLine="true"
                    android:layout_marginBottom="12dp">

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chipSd"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="SD"
                        android:clickable="false"
                        android:checkable="false"
                        app:chipMinHeight="32dp"
                        app:chipBackgroundColor="@color/pb_surface_variant"/>

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chipImu"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="IMU"
                        android:clickable="false"
                        android:checkable="false"
                        app:chipMinHeight="32dp"
                        app:chipBackgroundColor="@color/pb_surface_variant"/>

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chipHx711"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="HX711"
                        android:clickable="false"
                        android:checkable="false"
                        app:chipMinHeight="32dp"
                        app:chipBackgroundColor="@color/pb_surface_variant"/>

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chipWifi"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="WiFi"
                        android:clickable="false"
                        android:checkable="false"
                        app:chipMinHeight="32dp"
                        app:chipBackgroundColor="@color/pb_surface_variant"/>

                </com.google.android.material.chip.ChipGroup>

                <TextView
                    android:id="@+id/tvTimeSyncState"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/state_time_sync_unknown"
                    android:textSize="12sp"
                    android:textColor="?attr/colorOnSurface"
                    android:alpha="0.55"/>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- ── Session State Card ─────────────────────────────────── -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="20dp"
            app:cardBackgroundColor="?attr/colorSurface"
            app:cardCornerRadius="16dp"
            app:cardElevation="2dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="SESSION"
                    android:textSize="11sp"
                    android:textAllCaps="true"
                    android:letterSpacing="0.08"
                    android:textColor="?attr/colorOnSurface"
                    android:alpha="0.55"
                    android:layout_marginBottom="8dp"/>

                <TextView
                    android:id="@+id/tvSessionState"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="—"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:textColor="?attr/colorOnSurface"/>

                <TextView
                    android:id="@+id/tvSamplesState"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text=""
                    android:textSize="14sp"
                    android:textColor="?attr/colorOnSurface"
                    android:alpha="0.65"
                    android:layout_marginTop="4dp"
                    android:visibility="invisible"/>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- ── Actions ───────────────────────────────────────────── -->
        <Button
            android:id="@+id/btnConnect"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="@string/action_connect"
            android:layout_marginBottom="10dp"
            android:backgroundTint="?attr/colorPrimary"/>

        <Button
            android:id="@+id/btnStartStop"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="@string/action_start"
            android:enabled="false"
            android:layout_marginBottom="10dp"
            android:backgroundTint="?attr/colorPrimary"/>

        <Button
            android:id="@+id/btnHistory"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="@string/action_session_history"
            android:layout_marginBottom="8dp"
            android:backgroundTint="?attr/colorTertiary"/>

        <Button
            android:id="@+id/btnSendSession"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="@string/action_send_session"
            android:layout_marginBottom="8dp"
            android:enabled="false"
            style="@style/Widget.Material3.Button.OutlinedButton"/>

        <!-- WiFi: secondary action, less prominent -->
        <Button
            android:id="@+id/btnWifi"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:text="@string/action_configure_wifi"
            android:enabled="false"
            style="@style/Widget.Material3.Button.TextButton"
            android:textColor="?attr/colorOnSurface"
            android:alpha="0.70"/>

    </LinearLayout>

</ScrollView>
