<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="horizontal"
    android:padding="12dp"
    android:background="?android:colorBackground">

    <!-- Left column: status -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:orientation="vertical"
        android:paddingEnd="8dp">

        <ImageView
            android:id="@+id/ivLogo"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginBottom="8dp"
            android:adjustViewBounds="true"
            android:scaleType="fitCenter"
            android:src="@drawable/petbionic_logo"
            android:contentDescription="@string/app_name" />

        <!-- Device card -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            app:cardBackgroundColor="?attr/colorSurface"
            app:cardCornerRadius="16dp"
            app:cardElevation="2dp"
            android:layout_marginBottom="8dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/device_status_label"
                    android:textSize="10sp"
                    android:textAllCaps="true"
                    android:textColor="?attr/colorOnSurface"
                    android:alpha="0.55"
                    android:layout_marginBottom="8dp"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="12dp">

                    <View
                        android:id="@+id/viewConnectionDot"
                        android:layout_width="10dp"
                        android:layout_height="10dp"
                        android:layout_marginEnd="8dp"
                        android:background="@drawable/circle_indicator"/>

                    <TextView
                        android:id="@+id/tvStatus"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/status_disconnected"
                        android:textSize="17sp"
                        android:textStyle="bold"
                        android:textColor="?attr/colorOnSurface"/>
                </LinearLayout>

                <com.google.android.material.chip.ChipGroup
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:singleLine="true"
                    android:layout_marginBottom="8dp">

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chipSd"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="SD"
                        android:clickable="false"
                        android:checkable="false"
                        app:chipMinHeight="28dp"
                        app:chipBackgroundColor="@color/pb_surface_variant"/>

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chipImu"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="IMU"
                        android:clickable="false"
                        android:checkable="false"
                        app:chipMinHeight="28dp"
                        app:chipBackgroundColor="@color/pb_surface_variant"/>

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chipHx711"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="HX711"
                        android:clickable="false"
                        android:checkable="false"
                        app:chipMinHeight="28dp"
                        app:chipBackgroundColor="@color/pb_surface_variant"/>

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chipWifi"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="WiFi"
                        android:clickable="false"
                        android:checkable="false"
                        app:chipMinHeight="28dp"
                        app:chipBackgroundColor="@color/pb_surface_variant"/>

                </com.google.android.material.chip.ChipGroup>

                <TextView
                    android:id="@+id/tvTimeSyncState"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/state_time_sync_unknown"
                    android:textSize="12sp"
                    android:textColor="?attr/colorOnSurface"
                    android:alpha="0.55"/>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Session card -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="?attr/colorSurface"
            app:cardCornerRadius="16dp"
            app:cardElevation="2dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="SESSION"
                    android:textSize="10sp"
                    android:textAllCaps="true"
                    android:textColor="?attr/colorOnSurface"
                    android:alpha="0.55"
                    android:layout_marginBottom="6dp"/>

                <TextView
                    android:id="@+id/tvSessionState"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="—"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="?attr/colorOnSurface"/>

                <TextView
                    android:id="@+id/tvSamplesState"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text=""
                    android:textSize="13sp"
                    android:textColor="?attr/colorOnSurface"
                    android:alpha="0.65"
                    android:layout_marginTop="2dp"
                    android:visibility="invisible"/>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

    </LinearLayout>

    <!-- Right column: actions -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:orientation="vertical"
        android:paddingStart="8dp">

        <Button
            android:id="@+id/btnConnect"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:text="@string/action_connect"
            android:layout_marginBottom="8dp"
            android:backgroundTint="?attr/colorPrimary"/>

        <Button
            android:id="@+id/btnStartStop"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:text="@string/action_start"
            android:enabled="false"
            android:layout_marginBottom="8dp"
            android:backgroundTint="?attr/colorPrimary"/>

        <Button
            android:id="@+id/btnHistory"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:text="@string/action_session_history"
            android:layout_marginBottom="6dp"
            android:backgroundTint="?attr/colorTertiary"/>

        <Button
            android:id="@+id/btnSendSession"
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:text="@string/action_send_session"
            android:enabled="false"
            android:layout_marginBottom="4dp"
            style="@style/Widget.Material3.Button.OutlinedButton"/>

        <Button
            android:id="@+id/btnWifi"
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:text="@string/action_configure_wifi"
            android:enabled="false"
            style="@style/Widget.Material3.Button.TextButton"
            android:textColor="?attr/colorOnSurface"
            android:alpha="0.70"/>

        <Space
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"/>
    </LinearLayout>

</LinearLayout>
